---
---

<section id="social" aria-labelledby="social-heading" class="py-16 md:py-20 border-t border-[var(--c-border)]">
  <div class="max-w-6xl mx-auto px-5 md:px-8">

    <div class="reveal mb-10">
      <span class="text-[#22d3ee] text-xs uppercase tracking-[0.2em] font-medium" aria-hidden="true">By the numbers</span>
      <h2 id="social-heading" class="mt-3 font-display text-2xl sm:text-3xl font-bold text-[var(--c-text-pri)]">Built in public</h2>
      <p class="mt-3 text-[var(--c-text-sec)] max-w-xl text-sm">Real output from building at night while running a business during the day.</p>
    </div>

    <dl class="reveal grid grid-cols-2 lg:grid-cols-4 gap-4" aria-label="Build statistics">

      <!-- 5+ projects -->
      <div
        class="card-hover bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl p-5 flex flex-col"
        data-delay="1"
      >
        <dt class="sr-only">Projects built</dt>
        <dd
          class="font-display font-bold text-[var(--c-text-pri)] leading-none mb-2 count-up grad-cyan"
          style="font-size:clamp(2rem,4vw,2.75rem)"
          aria-label="5+ projects built"
          data-count-to="5"
          data-count-suffix="+"
        >5+</dd>
        <p class="text-[var(--c-text-pri)] text-sm font-semibold mb-1">Projects built</p>
        <p class="text-[var(--c-text-mut)] text-xs leading-relaxed mt-auto pt-2 border-t border-[var(--c-border)]">Momentum Dash, SnuggSpec, Scraping School, Kyle Site, and more</p>
      </div>

      <!-- 40K+ lines of code -->
      <div
        class="card-hover bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl p-5 flex flex-col"
        data-delay="2"
      >
        <dt class="sr-only">Lines of code</dt>
        <dd
          class="font-display font-bold text-[var(--c-text-pri)] leading-none mb-2 count-up grad-cyan"
          style="font-size:clamp(2rem,4vw,2.75rem)"
          aria-label="40K+ lines of code"
          data-count-to="40"
          data-count-suffix="K+"
        >40K+</dd>
        <p class="text-[var(--c-text-pri)] text-sm font-semibold mb-1">Lines of code</p>
        <p class="text-[var(--c-text-mut)] text-xs leading-relaxed mt-auto pt-2 border-t border-[var(--c-border)]">Across active projects (estimated)</p>
      </div>

      <!-- 14 nightly tasks -->
      <div
        class="card-hover bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl p-5 flex flex-col"
        data-delay="3"
      >
        <dt class="sr-only">Nightly tasks</dt>
        <dd
          class="font-display font-bold text-[var(--c-text-pri)] leading-none mb-2 count-up grad-cyan"
          style="font-size:clamp(2rem,4vw,2.75rem)"
          aria-label="14 nightly tasks"
          data-count-to="14"
          data-count-suffix=""
        >14</dd>
        <p class="text-[var(--c-text-pri)] text-sm font-semibold mb-1">Nightly tasks</p>
        <p class="text-[var(--c-text-mut)] text-xs leading-relaxed mt-auto pt-2 border-t border-[var(--c-border)]">Automated overnight pipeline tasks running now</p>
      </div>

      <!-- 3+ years building -->
      <div
        class="card-hover bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl p-5 flex flex-col"
        data-delay="4"
      >
        <dt class="sr-only">Years building</dt>
        <dd
          class="font-display font-bold text-[var(--c-text-pri)] leading-none mb-2 count-up grad-cyan"
          style="font-size:clamp(2rem,4vw,2.75rem)"
          aria-label="3+ years building"
          data-count-to="3"
          data-count-suffix="+"
        >3+</dd>
        <p class="text-[var(--c-text-pri)] text-sm font-semibold mb-1">Years building</p>
        <p class="text-[var(--c-text-mut)] text-xs leading-relaxed mt-auto pt-2 border-t border-[var(--c-border)]">From first Python script to full-stack systems</p>
      </div>

    </dl>

    <!-- GitHub link -->
    <div class="reveal mt-8 flex flex-col sm:flex-row items-center gap-4 p-5 bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl">
      <div class="flex items-center gap-3 flex-1 min-w-0">
        <div class="w-10 h-10 rounded-xl bg-[rgba(34,211,238,0.1)] border border-[rgba(34,211,238,0.2)] flex items-center justify-center flex-shrink-0" aria-hidden="true">
          <!-- GitHub icon -->
          <svg aria-hidden="true" class="w-5 h-5 text-[#22d3ee]" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-[var(--c-text-pri)] text-sm font-semibold">github.com/kylekanooth</p>
          <p class="text-[var(--c-text-mut)] text-xs mt-0.5">Active repos across all four projects</p>
        </div>
      </div>
      <a
        href="https://github.com/kylekanooth"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost text-sm flex-shrink-0"
        aria-label="View Kyle Kanooth's GitHub profile (opens in new tab)"
      >
        View GitHub
        <svg aria-hidden="true" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
    </div>

  </div>
</section>
