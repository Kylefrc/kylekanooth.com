---
---

<header
  id="site-nav"
  role="banner"
  class="fixed inset-x-0 top-0 z-40 transition-all duration-300 nav-root"
>
  <div class="max-w-6xl mx-auto px-5 md:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="font-display text-lg font-semibold text-[var(--c-text-pri)] tracking-tight"
      aria-label="Kyle Kanooth — Home"
    >
      KK<span class="text-[#2D5016]" aria-hidden="true">.</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-7" aria-label="Primary navigation">
      <a href="#about"    class="nav-link text-sm text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors">About</a>
      <a href="#projects" class="nav-link text-sm text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors">Projects</a>
      <a href="/blog"     class="nav-link text-sm text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors">Blog</a>
      <a href="/now"      class="nav-link text-sm text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors">Now</a>
      <a href="/uses"     class="nav-link text-sm text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors">Uses</a>
      <a href="/resources" class="nav-link text-sm text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors">Resources</a>
      <a href="/rebate-calculator" class="nav-link text-sm text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors">Calculator</a>
      <a href="#contact"  class="nav-link text-sm text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors">Contact</a>
    </nav>

    <!-- Right controls -->
    <div class="flex items-center gap-3">
      <!-- Theme toggle — logic handled by BaseLayout -->
      <button
        data-theme-toggle
        class="theme-toggle focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-amber-600"
        aria-label="Toggle color theme"
        title="Toggle light / dark mode"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="nav-icon-sun" aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1"  x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1"  y1="12" x2="3"  y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64"  x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="nav-icon-moon" aria-hidden="true" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>

      <!-- Desktop CTA -->
      <a href="#contact" class="hidden md:inline-flex btn-primary text-sm">
        Get in touch
        <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Mobile hamburger -->
      <button
        id="nav-hamburger"
        class="md:hidden text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] p-2 -mr-2 transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg id="hamburger-open" aria-hidden="true" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="hamburger-close" aria-hidden="true" class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6"  y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav dropdown -->
  <nav
    id="mobile-nav"
    class="md:hidden hidden bg-[var(--c-surface)] border-b border-[var(--c-border)] px-5 py-4 space-y-1"
    aria-label="Mobile navigation"
  >
    <a href="#about"    class="block py-2.5 text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors mobile-nav-link">About</a>
    <a href="#projects" class="block py-2.5 text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors mobile-nav-link">Projects</a>
    <a href="/blog"     class="block py-2.5 text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors mobile-nav-link">Blog</a>
    <a href="/now"      class="block py-2.5 text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors mobile-nav-link">Now</a>
    <a href="/uses"     class="block py-2.5 text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors mobile-nav-link">Uses</a>
    <a href="/resources" class="block py-2.5 text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors mobile-nav-link">Resources</a>
    <a href="/rebate-calculator" class="block py-2.5 text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors mobile-nav-link">Calculator</a>
    <a href="#contact"  class="block py-2.5 text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors mobile-nav-link">Contact</a>
    <a href="#contact"  class="mt-3 block text-center btn-primary justify-center mobile-nav-link">Get in touch</a>
  </nav>
</header>

<style>
  /* Scrolled state — toggled by JS via data-scrolled attribute */
  .nav-root[data-scrolled] {
    background: var(--c-nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--c-border);
  }
</style>

<script>
  // ── Scroll detection ──
  const nav = document.getElementById('site-nav');
  const onScroll = () => {
    if (window.scrollY > 8) {
      nav?.setAttribute('data-scrolled', '');
    } else {
      nav?.removeAttribute('data-scrolled');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // run once on load

  // ── Mobile menu toggle ──
  const hamburger  = document.getElementById('nav-hamburger');
  const mobileNav  = document.getElementById('mobile-nav');
  const openIcon   = document.getElementById('hamburger-open');
  const closeIcon  = document.getElementById('hamburger-close');

  const setMenuOpen = (open) => {
    mobileNav?.classList.toggle('hidden', !open);
    hamburger?.setAttribute('aria-expanded', String(open));
    hamburger?.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
    if (open) {
      const first = /** @type {HTMLElement|null} */ (mobileNav?.querySelector('a'));
      first?.focus();
    }
  };

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.contains('hidden') === false;
    setMenuOpen(!isOpen);
  });

  // Close on mobile link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  // ── Escape key ──
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setMenuOpen(false);
  });

  // ── Theme icon sync ──
  const syncThemeIcons = () => {
    const isLight = document.documentElement.classList.contains('light');
    document.getElementById('nav-icon-sun')?.classList.toggle('hidden', isLight);
    document.getElementById('nav-icon-moon')?.classList.toggle('hidden', !isLight);
  };

  // Run once and observe html class changes
  syncThemeIcons();
  const observer = new MutationObserver(syncThemeIcons);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
