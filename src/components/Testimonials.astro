---
---

<section id="testimonials" aria-labelledby="testimonials-heading" class="py-20 md:py-28 border-t border-[var(--c-border)]">
  <div class="max-w-6xl mx-auto px-5 md:px-8">

    <div class="reveal mb-12">
      <span class="text-[#2D5016] text-xs uppercase tracking-[0.2em] font-medium" aria-hidden="true">Social Proof</span>
      <h2 id="testimonials-heading" class="mt-3 font-display text-3xl sm:text-4xl font-bold text-[var(--c-text-pri)]">What people say</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" role="list" aria-label="Testimonials">

      <!-- HVAC Ops Manager -->
      <figure
        role="listitem"
        class="reveal card-hover bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl p-6 flex flex-col"
        data-delay="1"
      >
        <div class="flex items-center justify-between mb-5">
          <span
            class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full bg-[rgba(217,119,6,0.1)] border border-[rgba(217,119,6,0.3)] text-[#D97706]"
            aria-label="This testimonial is a placeholder"
          >
            <svg aria-hidden="true" viewBox="0 0 12 12" fill="none" class="w-2.5 h-2.5">
              <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 4v2.5M6 8h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Placeholder
          </span>
          <span class="text-xs text-[var(--c-text-mut)] px-2 py-0.5 rounded bg-[rgba(38,38,38,0.6)]">AI Automation</span>
        </div>

        <div aria-hidden="true" class="text-[rgba(45,80,22,0.3)] font-display font-bold leading-none mb-3" style="font-size:3.5rem;line-height:1">&#8220;</div>

        <blockquote class="flex-1">
          <p class="text-[var(--c-text-sec)] text-sm leading-relaxed italic">
            The overnight QC pipeline Kyle built caught three unbilled completed jobs in the first week alone. We used to find these in quarterly reviews — six weeks too late. Now we catch them before the morning huddle. The system has more than paid for itself.
          </p>
        </blockquote>

        <figcaption class="mt-5 flex items-center gap-3 pt-5 border-t border-[var(--c-border)]">
          <div
            class="w-10 h-10 rounded-full bg-[rgba(45,80,22,0.1)] border border-[rgba(45,80,22,0.2)] flex items-center justify-center flex-shrink-0"
            aria-hidden="true"
          >
            <span class="text-[#2D5016] font-semibold text-xs font-display">JM</span>
          </div>
          <div class="min-w-0">
            <p class="text-[var(--c-text-pri)] text-sm font-semibold leading-tight">James M.</p>
            <p class="text-[var(--c-text-mut)] text-xs mt-0.5 truncate">Operations Manager &mdash; Portland HVAC Co.</p>
          </div>
        </figcaption>
      </figure>

      <!-- Senior Engineer -->
      <figure
        role="listitem"
        class="reveal card-hover bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl p-6 flex flex-col"
        data-delay="2"
      >
        <div class="flex items-center justify-between mb-5">
          <span
            class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full bg-[rgba(217,119,6,0.1)] border border-[rgba(217,119,6,0.3)] text-[#D97706]"
            aria-label="This testimonial is a placeholder"
          >
            <svg aria-hidden="true" viewBox="0 0 12 12" fill="none" class="w-2.5 h-2.5">
              <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 4v2.5M6 8h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Placeholder
          </span>
          <span class="text-xs text-[var(--c-text-mut)] px-2 py-0.5 rounded bg-[rgba(38,38,38,0.6)]">Technical Collaboration</span>
        </div>

        <div aria-hidden="true" class="text-[rgba(45,80,22,0.3)] font-display font-bold leading-none mb-3" style="font-size:3.5rem;line-height:1">&#8220;</div>

        <blockquote class="flex-1">
          <p class="text-[var(--c-text-sec)] text-sm leading-relaxed italic">
            Kyle shipped a full FastAPI + React system over a long weekend that would have taken most junior engineers two months. The code was clean, typed, and had tests. What impressed me most was his architecture instincts — he'd been building for less than two years.
          </p>
        </blockquote>

        <figcaption class="mt-5 flex items-center gap-3 pt-5 border-t border-[var(--c-border)]">
          <div
            class="w-10 h-10 rounded-full bg-[rgba(45,80,22,0.1)] border border-[rgba(45,80,22,0.2)] flex items-center justify-center flex-shrink-0"
            aria-hidden="true"
          >
            <span class="text-[#2D5016] font-semibold text-xs font-display">SR</span>
          </div>
          <div class="min-w-0">
            <p class="text-[var(--c-text-pri)] text-sm font-semibold leading-tight">Sarah R.</p>
            <p class="text-[var(--c-text-mut)] text-xs mt-0.5 truncate">Senior Engineer &mdash; Portland Tech</p>
          </div>
        </figcaption>
      </figure>

      <!-- CTO -->
      <figure
        role="listitem"
        class="reveal card-hover bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl p-6 flex flex-col"
        data-delay="3"
      >
        <div class="flex items-center justify-between mb-5">
          <span
            class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full bg-[rgba(217,119,6,0.1)] border border-[rgba(217,119,6,0.3)] text-[#D97706]"
            aria-label="This testimonial is a placeholder"
          >
            <svg aria-hidden="true" viewBox="0 0 12 12" fill="none" class="w-2.5 h-2.5">
              <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 4v2.5M6 8h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Placeholder
          </span>
          <span class="text-xs text-[var(--c-text-mut)] px-2 py-0.5 rounded bg-[rgba(38,38,38,0.6)]">Technical Recruiting</span>
        </div>

        <div aria-hidden="true" class="text-[rgba(45,80,22,0.3)] font-display font-bold leading-none mb-3" style="font-size:3.5rem;line-height:1">&#8220;</div>

        <blockquote class="flex-1">
          <p class="text-[var(--c-text-sec)] text-sm leading-relaxed italic">
            Kyle sent us three candidates. We hired two. That's unheard of. He actually read their GitHub before sending them over — one of them had an open-source project directly relevant to our stack. Most recruiters would never have caught that.
          </p>
        </blockquote>

        <figcaption class="mt-5 flex items-center gap-3 pt-5 border-t border-[var(--c-border)]">
          <div
            class="w-10 h-10 rounded-full bg-[rgba(45,80,22,0.1)] border border-[rgba(45,80,22,0.2)] flex items-center justify-center flex-shrink-0"
            aria-hidden="true"
          >
            <span class="text-[#2D5016] font-semibold text-xs font-display">DP</span>
          </div>
          <div class="min-w-0">
            <p class="text-[var(--c-text-pri)] text-sm font-semibold leading-tight">David P.</p>
            <p class="text-[var(--c-text-mut)] text-xs mt-0.5 truncate">CTO &mdash; Series A SaaS</p>
          </div>
        </figcaption>
      </figure>

    </div>

    <p class="reveal mt-8 text-center text-xs text-[var(--c-text-mut)]">
      Real testimonials will replace these placeholders. If you've worked with Kyle and would like to provide one,{' '}
      <a href="#contact" class="text-[#2D5016] hover:text-[#6B8F5E] transition-colors link-animated">reach out</a>.
    </p>

  </div>
</section>
