---
---

<section
  aria-labelledby="hero-heading"
  class="relative min-h-screen flex items-center pt-16 overflow-hidden hero-noise grid-lines"
>
  <!-- Ambient glows — decorative -->
  <div
    aria-hidden="true"
    class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-[#22d3ee]/5 blur-3xl pointer-events-none"
  ></div>
  <div
    aria-hidden="true"
    class="absolute top-1/3 -right-32 w-[400px] h-[400px] rounded-full bg-[#fbbf24]/5 blur-3xl pointer-events-none"
  ></div>

  <div class="relative max-w-6xl mx-auto px-5 md:px-8 py-20 md:py-28">
    <div class="max-w-3xl">
      <!-- Location badge -->
      <div class="reveal flex items-center gap-2 mb-6">
        <span class="w-2 h-2 bg-[#22d3ee] rounded-full animate-pulse" aria-hidden="true"></span>
        <span class="text-[#22d3ee] text-sm font-medium tracking-wide">Portland, OR</span>
      </div>

      <!-- Name -->
      <h1
        id="hero-heading"
        class="reveal font-display text-5xl sm:text-6xl md:text-7xl font-bold leading-[1.05] text-[var(--c-text-pri)] tracking-tight"
        data-delay="1"
      >
        Kyle Kanooth
      </h1>

      <!-- Subtitle -->
      <p
        class="reveal mt-4 font-display text-xl sm:text-2xl md:text-3xl font-medium"
        role="doc-subtitle"
        data-delay="2"
      >
        <span class="grad-cyan">Building at the intersection</span><br class="hidden sm:block" /> of energy, AI, and automation.
      </p>

      <!-- Body -->
      <p
        class="reveal mt-6 text-lg text-[var(--c-text-sec)] max-w-xl leading-relaxed"
        data-delay="3"
      >
        Energy efficiency consultant by day. I sell heat pumps and insulation retrofits to Portland homeowners — real work, real impact. Nights and weekends I build: software, agents, and systems that run while I sleep.
      </p>

      <!-- CTAs -->
      <div
        class="reveal mt-10 flex flex-wrap gap-4"
        role="group"
        aria-label="Primary actions"
        data-delay="4"
      >
        <a href="#projects" class="btn-primary">
          See what I build
          <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#contact" class="btn-ghost">Work together</a>
      </div>
    </div>
  </div>
</section>
