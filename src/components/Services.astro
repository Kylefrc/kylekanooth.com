---
---

<section id="services" aria-labelledby="services-heading" class="py-20 md:py-28 border-t border-[var(--c-border)]">
  <div class="max-w-6xl mx-auto px-5 md:px-8">

    <!-- Section header -->
    <div class="reveal mb-14">
      <span class="text-[#22d3ee] text-xs uppercase tracking-[0.2em] font-medium" aria-hidden="true">Services</span>
      <h2 id="services-heading" class="mt-3 font-display text-3xl sm:text-4xl font-bold text-[var(--c-text-pri)]">Work with me</h2>
      <p class="mt-3 text-[var(--c-text-sec)] max-w-xl">Three ways to work together — all rooted in actually doing the work, not just advising.</p>
    </div>

    <!-- AI Automation Consulting -->
    <article
      aria-labelledby="consulting-heading"
      class="reveal mb-10 bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl overflow-hidden service-glow"
    >
      <div class="px-7 pt-7 pb-6 border-b border-[var(--c-border)]">
        <div class="flex items-start gap-4">
          <div class="w-14 h-14 rounded-xl bg-[rgba(34,211,238,0.1)] border border-[rgba(34,211,238,0.2)] flex items-center justify-center flex-shrink-0" aria-hidden="true">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="w-7 h-7 text-[#22d3ee]">
              <path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 id="consulting-heading" class="font-display text-2xl font-bold text-[var(--c-text-pri)]">AI Automation Consulting</h3>
            <p class="mt-1.5 text-[#22d3ee] font-medium">I'll build the overnight automation system your business is missing.</p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[var(--c-border)]">
        <!-- Process -->
        <div class="px-6 py-6">
          <h4 class="text-xs uppercase tracking-[0.18em] text-[var(--c-text-mut)] font-medium mb-4">Process</h4>
          <ol class="space-y-4" aria-label="AI Automation Consulting process">
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">1</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Discovery Call</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">We map your current workflow and identify the highest-leverage automation targets.</p>
            </li>
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">2</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Audit &amp; Roadmap</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">Written assessment of your systems, data sources, and a prioritized build plan.</p>
            </li>
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">3</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Implementation</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">I build the pipelines, agents, and integrations — you review at every checkpoint.</p>
            </li>
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">4</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Monitoring &amp; Iteration</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">Ongoing tuning, alert handling, and expanding coverage as the system matures.</p>
            </li>
          </ol>
        </div>

        <!-- What you get -->
        <div class="px-6 py-6">
          <h4 class="text-xs uppercase tracking-[0.18em] text-[var(--c-text-mut)] font-medium mb-4">What you get</h4>
          <ul class="space-y-2.5" aria-label="AI Automation Consulting inclusions">
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Overnight automation — pipelines that work while you sleep</span>
            </li>
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>ServiceTitan API integration for field service companies</span>
            </li>
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>AI-powered QC catches errors before they cost money</span>
            </li>
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Data pipelines: extract, validate, report, alert</span>
            </li>
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Claude Code + MCP agent architecture</span>
            </li>
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Team training so your people can maintain what I build</span>
            </li>
          </ul>
        </div>

        <!-- Pricing + CTA -->
        <div class="px-6 py-6 flex flex-col">
          <div class="flex items-center gap-2 mb-4">
            <h4 class="text-xs uppercase tracking-[0.18em] text-[var(--c-text-mut)] font-medium">Pricing</h4>
            <span class="inline-flex items-center gap-1 text-[0.65rem] font-medium px-2 py-0.5 rounded-full bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] text-[#fbbf24]">
              <svg aria-hidden="true" viewBox="0 0 12 12" fill="none" class="w-2.5 h-2.5"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M6 4v2.5M6 8h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Placeholder
            </span>
          </div>
          <div class="space-y-3 flex-1">
            <!-- Starter -->
            <div class="p-3 rounded-xl bg-[var(--c-bg)] border border-[var(--c-border)]">
              <div class="flex items-center justify-between mb-1">
                <p class="text-sm font-semibold text-[var(--c-text-pri)]">Starter</p>
                <p class="text-sm font-bold text-[#22d3ee]">$X</p>
              </div>
              <p class="text-xs text-[var(--c-text-sec)]">One-time automation audit + written roadmap. Know exactly what to build and in what order.</p>
            </div>
            <!-- Growth (featured) -->
            <div class="p-3 rounded-xl bg-[rgba(34,211,238,0.06)] border border-[rgba(34,211,238,0.25)]">
              <div class="flex items-center justify-between mb-1">
                <p class="text-sm font-semibold text-[var(--c-text-pri)]">Growth <span class="text-[0.6rem] text-[#22d3ee] ml-1">Popular</span></p>
                <p class="text-sm font-bold text-[#22d3ee]">$X / mo</p>
              </div>
              <p class="text-xs text-[var(--c-text-sec)]">Monthly automation builds, monitoring, and iteration. Best for businesses with ongoing workflow needs.</p>
            </div>
            <!-- Enterprise -->
            <div class="p-3 rounded-xl bg-[var(--c-bg)] border border-[var(--c-border)]">
              <div class="flex items-center justify-between mb-1">
                <p class="text-sm font-semibold text-[var(--c-text-pri)]">Enterprise</p>
                <p class="text-sm font-bold text-[#22d3ee]">$X / mo</p>
              </div>
              <p class="text-xs text-[var(--c-text-sec)]">Full-stack AI integration, custom builds, and dedicated async support. For complex, multi-system environments.</p>
            </div>
          </div>
          <a href="#contact" class="mt-6 btn-primary justify-center text-sm" aria-label="Book a discovery call for AI Automation Consulting">
            Book a Discovery Call
            <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <p class="mt-3 text-center text-xs text-[var(--c-text-mut)]">No commitment. 30-minute call to see if it's a fit.</p>
        </div>
      </div>
    </article>

    <!-- Technical Recruiting -->
    <article
      aria-labelledby="recruiting-heading"
      class="reveal mb-10 bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl overflow-hidden service-glow"
    >
      <div class="px-7 pt-7 pb-6 border-b border-[var(--c-border)]">
        <div class="flex items-start gap-4">
          <div class="w-14 h-14 rounded-xl bg-[rgba(34,211,238,0.1)] border border-[rgba(34,211,238,0.2)] flex items-center justify-center flex-shrink-0" aria-hidden="true">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="w-7 h-7 text-[#22d3ee]">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 id="recruiting-heading" class="font-display text-2xl font-bold text-[var(--c-text-pri)]">Technical Recruiting</h3>
            <p class="mt-1.5 text-[#22d3ee] font-medium">I connect companies with engineers who actually build — because I'm one of them.</p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[var(--c-border)]">
        <!-- Process -->
        <div class="px-6 py-6">
          <h4 class="text-xs uppercase tracking-[0.18em] text-[var(--c-text-mut)] font-medium mb-4">Process</h4>
          <ol class="space-y-4" aria-label="Technical Recruiting process">
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">1</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Needs Analysis</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">Deep dive into the role, team, stack, and what "great" actually looks like for you.</p>
            </li>
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">2</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Sourcing</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">Targeted outreach to engineers with proven output — not just keyword-matched resumes.</p>
            </li>
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">3</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Screening</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">I review their code and talk through their architecture decisions before you see a profile.</p>
            </li>
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">4</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Placement</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">Introductions, interview support, and offer coordination through close.</p>
            </li>
          </ol>
        </div>

        <!-- Focus areas -->
        <div class="px-6 py-6">
          <h4 class="text-xs uppercase tracking-[0.18em] text-[var(--c-text-mut)] font-medium mb-4">Focus areas</h4>
          <ul class="space-y-2.5" aria-label="Technical Recruiting focus areas">
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>AI/ML engineers (LLM integration, agents, fine-tuning)</span>
            </li>
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Full-stack developers (Python + TypeScript preferred)</span>
            </li>
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Data engineers and pipeline builders</span>
            </li>
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Energy tech and field service software specialists</span>
            </li>
            <li class="flex items-start gap-2.5 text-sm text-[var(--c-text-sec)]">
              <svg aria-hidden="true" class="w-4 h-4 text-[#22d3ee] flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>SaaS product engineers at seed through Series B</span>
            </li>
          </ul>
          <div class="mt-6 p-4 rounded-xl bg-[var(--c-bg)] border border-[var(--c-border)]">
            <p class="text-xs text-[var(--c-text-mut)] leading-relaxed">
              <span class="font-semibold text-[var(--c-text-sec)]">The differentiator:</span> I read the code before you do.
              Candidates get a real technical conversation, not a keyword screen. You get fewer interviews with better signal.
            </p>
          </div>
        </div>

        <!-- Pricing + CTA -->
        <div class="px-6 py-6 flex flex-col">
          <div class="flex items-center gap-2 mb-4">
            <h4 class="text-xs uppercase tracking-[0.18em] text-[var(--c-text-mut)] font-medium">Pricing</h4>
            <span class="inline-flex items-center gap-1 text-[0.65rem] font-medium px-2 py-0.5 rounded-full bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] text-[#fbbf24]">
              <svg aria-hidden="true" viewBox="0 0 12 12" fill="none" class="w-2.5 h-2.5"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M6 4v2.5M6 8h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Placeholder
            </span>
          </div>
          <p class="text-xs text-[var(--c-text-mut)] mb-4 leading-relaxed">Success-based — you pay on placement, not on effort. Percentages are negotiated per engagement.</p>
          <div class="space-y-3 flex-1">
            <!-- Contingency -->
            <div class="p-3 rounded-xl bg-[var(--c-bg)] border border-[var(--c-border)]">
              <div class="flex items-center justify-between mb-1">
                <p class="text-sm font-semibold text-[var(--c-text-pri)]">Contingency</p>
                <p class="text-sm font-bold text-[#22d3ee]">X%</p>
              </div>
              <p class="text-xs text-[var(--c-text-sec)]">No upfront cost. Fee on successful placement only. Best for single-role searches.</p>
            </div>
            <!-- Retained (featured) -->
            <div class="p-3 rounded-xl bg-[rgba(34,211,238,0.06)] border border-[rgba(34,211,238,0.25)]">
              <div class="flex items-center justify-between mb-1">
                <p class="text-sm font-semibold text-[var(--c-text-pri)]">Retained <span class="text-[0.6rem] text-[#22d3ee] ml-1">Recommended</span></p>
                <p class="text-sm font-bold text-[#22d3ee]">X% split</p>
              </div>
              <p class="text-xs text-[var(--c-text-sec)]">Priority engagement, exclusivity, and deeper search investment. Best for senior or hard-to-fill roles.</p>
            </div>
          </div>
          <a href="#contact" class="mt-6 btn-primary justify-center text-sm" aria-label="Start hiring with Technical Recruiting">
            Start Hiring
            <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <p class="mt-3 text-center text-xs text-[var(--c-text-mut)]">Tell me the role. I'll tell you if I can help.</p>
        </div>
      </div>
    </article>

    <!-- Energy Efficiency Consulting -->
    <article
      aria-labelledby="energy-heading"
      class="reveal bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl overflow-hidden service-glow"
    >
      <div class="px-7 pt-7 pb-6 border-b border-[var(--c-border)]">
        <div class="flex items-start gap-4">
          <div class="w-14 h-14 rounded-xl bg-[rgba(34,211,238,0.1)] border border-[rgba(34,211,238,0.2)] flex items-center justify-center flex-shrink-0" aria-hidden="true">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="w-7 h-7 text-[#22d3ee]">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
              <path d="M9 22V12h6v10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 id="energy-heading" class="font-display text-2xl font-bold text-[var(--c-text-pri)]">Energy Efficiency Consulting</h3>
            <p class="mt-1.5 text-[#22d3ee] font-medium">Whole-home energy upgrades with maximum rebate stacking. Portland/Vancouver area.</p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[var(--c-border)]">
        <!-- Process -->
        <div class="px-6 py-6">
          <h4 class="text-xs uppercase tracking-[0.18em] text-[var(--c-text-mut)] font-medium mb-4">Process</h4>
          <ol class="space-y-4" aria-label="Energy Efficiency Consulting process">
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">1</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Free Assessment</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">I walk your home, check insulation levels, air sealing, ductwork, and equipment — no sales pitch.</p>
            </li>
            <li class="relative pl-8">
              <span class="absolute left-0 top-0 w-5 h-5 rounded-full bg-[rgba(34,211,238,0.15)] border border-[rgba(34,211,238,0.3)] flex items-center justify-center text-[#22d3ee] text-[0.6rem] font-bold font-display" aria-hidden="true">2</span>
              <p class="text-sm font-medium text-[var(--c-text-pri)] leading-tight">Rebate Stacking</p>
              <p class="text-xs text-[var(--c-text-sec)] mt-0.5 leading-relaxed">I map every available incentive: ETO, PCEF, Clark PUD, federal 25C/25D tax credits — then sequence them for maximum value.</p>
            </li>
