---
---

<section id="projects" aria-labelledby="projects-heading" class="py-20 md:py-28 border-t border-[var(--c-border)]">
  <div class="max-w-6xl mx-auto px-5 md:px-8">

    <div class="reveal mb-12">
      <span class="text-[#22d3ee] text-xs uppercase tracking-[0.2em] font-medium" aria-hidden="true">What I Build</span>
      <h2 id="projects-heading" class="mt-3 font-display text-3xl sm:text-4xl font-bold text-[var(--c-text-pri)]">What I'm building</h2>
      <p class="mt-3 text-[var(--c-text-sec)] max-w-xl">Tools and products built at night, automated with AI, targeting real revenue.</p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5" role="list" aria-label="Project list">

      <!-- Momentum Dash -->
      <div role="listitem" class="reveal card-tilt" data-delay="1">
        <article class="bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl overflow-hidden flex flex-col h-full">
          <div class="p-6 flex flex-col flex-1">
            <div class="flex items-start justify-between gap-3 mb-4">
              <div>
                <p class="text-[var(--c-text-mut)] text-xs uppercase tracking-widest mb-1">Trading Dashboard</p>
                <h3 class="font-display text-xl font-semibold text-[var(--c-text-pri)]">Momentum Dash</h3>
              </div>
              <span class="flex-shrink-0 text-xs font-medium px-2.5 py-1 rounded-full border bg-[rgba(34,211,238,0.1)] text-[#67e8f9] border-[rgba(34,211,238,0.2)]" aria-label="Status: Active build">
                Active build
              </span>
            </div>

            <!-- Mockup: MomentumDash -->
            <div class="mb-4">
              <div class="mockup-placeholder w-full h-44 flex flex-col p-3 gap-2" aria-hidden="true">
                <div class="flex items-center gap-2 mb-1">
                  <span style="font-size:0.6rem;color:#22d3ee;font-family:monospace">AAPL</span>
                  <span style="font-size:0.6rem;color:#4ade80;font-family:monospace">+1.34%</span>
                  <span style="font-size:0.6rem;color:#7a8a9d;font-family:monospace;margin-left:auto">1D · RSI · MACD</span>
                </div>
                <svg viewBox="0 0 220 72" class="w-full flex-1" style="overflow:visible">
                  <polyline points="0,55 20,48 40,50 60,38 80,42 100,30 120,26 140,34 160,22 180,18 200,14 220,20" fill="none" stroke="#22d3ee" stroke-width="1.5" stroke-linejoin="round" opacity="0.8"/>
                  <polygon points="0,55 20,48 40,50 60,38 80,42 100,30 120,26 140,34 160,22 180,18 200,14 220,20 220,72 0,72" fill="url(#chartGrad)" opacity="0.15"/>
                  <defs>
                    <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="#22d3ee" stop-opacity="0.6"/>
                      <stop offset="100%" stop-color="#22d3ee" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                  <polyline points="0,68 30,65 60,62 90,66 120,60 150,58 180,63 220,61" fill="none" stroke="#f59e0b" stroke-width="1" opacity="0.5"/>
                  <line x1="0" y1="0" x2="220" y2="0" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
                  <line x1="0" y1="24" x2="220" y2="24" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
                  <line x1="0" y1="48" x2="220" y2="48" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
                  <line x1="0" y1="72" x2="220" y2="72" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
                </svg>
                <div class="flex gap-1.5">
                  <span style="font-size:0.5rem;background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.2);color:#67e8f9;border-radius:4px;padding:1px 5px;font-family:monospace">Top Gainer</span>
                  <span style="font-size:0.5rem;background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.2);color:#67e8f9;border-radius:4px;padding:1px 5px;font-family:monospace">High Vol</span>
                  <span style="font-size:0.5rem;background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.2);color:#67e8f9;border-radius:4px;padding:1px 5px;font-family:monospace">Gap Up</span>
                  <span style="font-size:0.5rem;background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.2);color:#67e8f9;border-radius:4px;padding:1px 5px;font-family:monospace">Breakout</span>
                </div>
              </div>
            </div>

            <p class="text-[var(--c-text-sec)] text-sm leading-relaxed flex-1">A personal day-trading dashboard with real-time charts, six scanner types, news feed, and watchlists. Built to replace a $150/mo SaaS subscription.</p>

            <div class="mt-4 grid grid-cols-3 gap-3" aria-label="Key metrics for Momentum Dash">
              <div class="text-center p-2 rounded-lg bg-[rgba(10,10,10,0.6)] border border-[rgba(38,38,38,0.5)]">
                <p class="font-display text-sm font-bold text-[#22d3ee]">6</p>
                <p class="text-[0.65rem] text-[var(--c-text-mut)] mt-0.5 leading-tight">Scanner types</p>
              </div>
              <div class="text-center p-2 rounded-lg bg-[rgba(10,10,10,0.6)] border border-[rgba(38,38,38,0.5)]">
                <p class="font-display text-sm font-bold text-[#22d3ee]">$150/mo</p>
                <p class="text-[0.65rem] text-[var(--c-text-mut)] mt-0.5 leading-tight">SaaS cost replaced</p>
              </div>
              <div class="text-center p-2 rounded-lg bg-[rgba(10,10,10,0.6)] border border-[rgba(38,38,38,0.5)]">
                <p class="font-display text-sm font-bold text-[#22d3ee]">3+</p>
                <p class="text-[0.65rem] text-[var(--c-text-mut)] mt-0.5 leading-tight">Chart indicators</p>
              </div>
            </div>

            <ul class="mt-5 flex flex-wrap gap-2" aria-label="Technologies used in Momentum Dash">
              <li class="tag">React</li>
              <li class="tag">TypeScript</li>
              <li class="tag">Tailwind</li>
              <li class="tag">FastAPI</li>
              <li class="tag">Alpaca API</li>
            </ul>

            <div class="mt-5 flex items-center justify-between gap-3">
              <a href="#contact" class="inline-flex items-center gap-1.5 text-[#22d3ee] text-sm font-medium hover:text-[#67e8f9] transition-colors">
                Learn more
                <svg aria-hidden="true" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <button
                class="project-toggle inline-flex items-center gap-1.5 text-sm font-medium text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors"
                aria-expanded="false"
                aria-controls="detail-momentum-dash"
              >
                <span class="toggle-label">More detail</span>
                <svg aria-hidden="true" viewBox="0 0 20 20" fill="none" class="chevron-icon w-4 h-4">
                  <path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>

          <div id="detail-momentum-dash" class="detail-panel collapsed border-t border-[var(--c-border)]" aria-hidden="true">
            <div class="p-6 pt-5">
              <h4 class="font-display text-base font-semibold text-[var(--c-text-pri)] mb-3">What it does</h4>
              <p class="text-sm text-[var(--c-text-sec)] leading-relaxed mb-4">
                Real-time charting with RSI, MACD, and Bollinger Bands overlaid on live Alpaca market data.
                Six scanner types — top gainers, high volume, gap-ups, breakouts, sector movers, and news catalysts —
                update on a configurable tick. Watchlists persist to a FastAPI backend with SQLite. The goal: a
                Day Trade Dash clone that runs for free on my own hardware.
              </p>
              <div class="grid sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <h5 class="text-xs uppercase tracking-widest text-[var(--c-text-mut)] mb-2">Key features</h5>
                  <ul class="space-y-1.5">
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Live Alpaca WebSocket feed</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>RSI / MACD / Bollinger overlays</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>6 scanner types with configurable filters</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Persistent watchlists via REST API</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>News feed with catalyst tagging</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Dark mode, keyboard shortcuts</li>
                  </ul>
                </div>
                <div>
                  <h5 class="text-xs uppercase tracking-widest text-[var(--c-text-mut)] mb-2">Architecture</h5>
                  <ul class="space-y-1.5">
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>React 18 + TypeScript frontend</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>FastAPI backend with WebSockets</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>SQLite for persistence</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Alpaca Markets paper/live API</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Deployed locally, Tailwind CDN</li>
                  </ul>
                </div>
              </div>
              <p class="text-xs text-[var(--c-text-mut)] italic">Status: M1 (auth + charting) and M2 (scanners) complete. M3 (news + alerts) in progress.</p>
            </div>
          </div>
        </article>
      </div>

      <!-- SnuggSpec -->
      <div role="listitem" class="reveal card-tilt" data-delay="2">
        <article class="bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl overflow-hidden flex flex-col h-full">
          <div class="p-6 flex flex-col flex-1">
            <div class="flex items-start justify-between gap-3 mb-4">
              <div>
                <p class="text-[var(--c-text-mut)] text-xs uppercase tracking-widest mb-1">Energy Audit SaaS</p>
                <h3 class="font-display text-xl font-semibold text-[var(--c-text-pri)]">SnuggSpec</h3>
              </div>
              <span class="flex-shrink-0 text-xs font-medium px-2.5 py-1 rounded-full border bg-[rgba(34,211,238,0.1)] text-[#67e8f9] border-[rgba(34,211,238,0.2)]" aria-label="Status: Active build">
                Active build
              </span>
            </div>

            <!-- Mockup: SnuggSpec -->
            <div class="mb-4">
              <div class="mockup-placeholder w-full h-44 flex flex-col p-3 gap-2" aria-hidden="true">
                <div class="flex items-center gap-2">
                  <div style="width:8px;height:8px;border-radius:50%;background:#22d3ee"></div>
                  <span style="font-size:0.6rem;color:#a5f3fc;font-family:monospace">SnuggSpec — Job #ST-4821</span>
                  <span style="font-size:0.55rem;background:rgba(74,222,128,0.15);color:#4ade80;border:1px solid rgba(74,222,128,0.25);border-radius:4px;padding:0px 4px;margin-left:auto;font-family:monospace">BPI Valid</span>
                </div>
                <div class="flex flex-col gap-1 flex-1">
                  <div class="flex items-center gap-2">
                    <span style="font-size:0.55rem;color:#7a8a9d;width:68px;flex-shrink:0;font-family:monospace">Blower Door</span>
                    <span style="font-size:0.55rem;color:#f8fafc;flex:1;font-family:monospace">3.2 ACH50</span>
                    <div style="width:32px;height:4px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden"><div style="width:92%;height:100%;background:#22d3ee;border-radius:2px"></div></div>
                    <span style="font-size:0.5rem;color:#7a8a9d;width:22px;text-align:right;font-family:monospace">92%</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span style="font-size:0.55rem;color:#7a8a9d;width:68px;flex-shrink:0;font-family:monospace">Insulation R-val</span>
                    <span style="font-size:0.55rem;color:#f8fafc;flex:1;font-family:monospace">R-38 attic</span>
                    <div style="width:32px;height:4px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden"><div style="width:88%;height:100%;background:#f59e0b;border-radius:2px"></div></div>
                    <span style="font-size:0.5rem;color:#7a8a9d;width:22px;text-align:right;font-family:monospace">88%</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span style="font-size:0.55rem;color:#7a8a9d;width:68px;flex-shrink:0;font-family:monospace">HVAC size</span>
                    <span style="font-size:0.55rem;color:#f8fafc;flex:1;font-family:monospace">2.5 ton HP</span>
                    <div style="width:32px;height:4px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden"><div style="width:95%;height:100%;background:#22d3ee;border-radius:2px"></div></div>
                    <span style="font-size:0.5rem;color:#7a8a9d;width:22px;text-align:right;font-family:monospace">95%</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span style="font-size:0.55rem;color:#7a8a9d;width:68px;flex-shrink:0;font-family:monospace">Window type</span>
                    <span style="font-size:0.55rem;color:#f8fafc;flex:1;font-family:monospace">Double-pane</span>
                    <div style="width:32px;height:4px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden"><div style="width:79%;height:100%;background:#f87171;border-radius:2px"></div></div>
                    <span style="font-size:0.5rem;color:#7a8a9d;width:22px;text-align:right;font-family:monospace">79%</span>
                  </div>
                </div>
                <div style="background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.25);border-radius:6px;padding:3px 8px;text-align:center">
                  <span style="font-size:0.55rem;color:#22d3ee;font-family:monospace">Push to SNUGG Pro →</span>
                </div>
              </div>
            </div>

            <p class="text-[var(--c-text-sec)] text-sm leading-relaxed flex-1">Cuts hours out of the energy auditor workflow. Pull a ServiceTitan job, validate against BPI standards, and push a fully-populated spec to SNUGG Pro — with confidence scoring on every field.</p>

            <div class="mt-4 grid grid-cols-3 gap-3" aria-label="Key metrics for SnuggSpec">
              <div class="text-center p-2 rounded-lg bg-[rgba(10,10,10,0.6)] border border-[rgba(38,38,38,0.5)]">
                <p class="font-display text-sm font-bold text-[#22d3ee]">$50–100/mo</p>
                <p class="text-[0.65rem] text-[var(--c-text-mut)] mt-0.5 leading-tight">Target price</p>
              </div>
              <div class="text-center p-2 rounded-lg bg-[rgba(10,10,10,0.6)] border border-[rgba(38,38,38,0.5)]">
                <p class="font-display text-sm font-bold text-[#22d3ee]">[TBD]</p>
                <p class="text-[0.65rem] text-[var(--c-text-mut)] mt-0.5 leading-tight">Fields validated</p>
              </div>
              <div class="text-center p-2 rounded-lg bg-[rgba(10,10,10,0.6)] border border-[rgba(38,38,38,0.5)]">
                <p class="font-display text-sm font-bold text-[#22d3ee]">[TBD]h</p>
                <p class="text-[0.65rem] text-[var(--c-text-mut)] mt-0.5 leading-tight">Time saved/audit</p>
              </div>
            </div>

            <ul class="mt-5 flex flex-wrap gap-2" aria-label="Technologies used in SnuggSpec">
              <li class="tag">React</li>
              <li class="tag">TypeScript</li>
              <li class="tag">FastAPI</li>
              <li class="tag">SQLite</li>
              <li class="tag">Playwright</li>
            </ul>

            <div class="mt-5 flex items-center justify-between gap-3">
              <a href="#contact" class="inline-flex items-center gap-1.5 text-[#22d3ee] text-sm font-medium hover:text-[#67e8f9] transition-colors">
                Learn more
                <svg aria-hidden="true" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <button
                class="project-toggle inline-flex items-center gap-1.5 text-sm font-medium text-[var(--c-text-sec)] hover:text-[var(--c-text-pri)] transition-colors"
                aria-expanded="false"
                aria-controls="detail-snugg-spec"
              >
                <span class="toggle-label">More detail</span>
                <svg aria-hidden="true" viewBox="0 0 20 20" fill="none" class="chevron-icon w-4 h-4">
                  <path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>

          <div id="detail-snugg-spec" class="detail-panel collapsed border-t border-[var(--c-border)]" aria-hidden="true">
            <div class="p-6 pt-5">
              <h4 class="font-display text-base font-semibold text-[var(--c-text-pri)] mb-3">What it does</h4>
              <p class="text-sm text-[var(--c-text-sec)] leading-relaxed mb-4">
                Energy auditors spend hours copying data between ServiceTitan, spreadsheets, and SNUGG Pro.
                SnuggSpec pulls a ST job via API, extracts structured audit fields (blower door, insulation,
                HVAC sizing, window type, etc.), validates them against BPI 2101 standards using Pydantic models,
                and uses Playwright to push the validated spec directly into SNUGG Pro — flagging low-confidence
                fields before they corrupt the energy model.
              </p>
              <div class="grid sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <h5 class="text-xs uppercase tracking-widest text-[var(--c-text-mut)] mb-2">Key features</h5>
                  <ul class="space-y-1.5">
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>ServiceTitan job pull via REST API</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>BPI 2101 field validation with Pydantic</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Per-field confidence scoring (0–100)</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Playwright-powered SNUGG Pro push</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Auditor review UI before submission</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Targeting $50–100/mo per seat</li>
                  </ul>
                </div>
                <div>
                  <h5 class="text-xs uppercase tracking-widest text-[var(--c-text-mut)] mb-2">Architecture</h5>
                  <ul class="space-y-1.5">
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>FastAPI backend + Pydantic v2 models</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>React + TypeScript review UI</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>SQLite job cache</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>Playwright for SNUGG Pro automation</li>
                    <li class="flex items-start gap-2 text-xs text-[var(--c-text-sec)]"><span class="mt-0.5 flex-shrink-0 text-[#22d3ee]" aria-hidden="true">›</span>ServiceTitan API integration</li>
                  </ul>
                </div>
              </div>
              <p class="text-xs text-[var(--c-text-mut)] italic">Status: spec builder and validation engine complete. SNUGG Pro push in testing.</p>
            </div>
          </div>
        </article>
      </div>

      <!-- Scraping School -->
      <div role="listitem" class="reveal card-tilt" data-delay="3">
        <article class="bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl overflow-hidden flex flex-col h-full">
          <div class="p-6 flex flex-col flex-1">
            <div class="flex items-start justify-between gap-3 mb-4">
              <div>
                <p class="text-[var(--c-text-mut)] text-xs uppercase tracking-widest mb-1">Web Scraping Course</p>
                <h3 class="font-display text-xl font-semibold text-[var(--c-text-pri)]">Scraping School</h3>
              </div>
              <span class="flex-shrink-0 text-xs font-medium px-2.5 py-1 rounded-full border bg-[rgba(251,191,36,0.1)] text-[#fbbf24] border-[rgba(251,191,36,0.2)]" aria-label="Status: In progress">
                In progress
              </span>
            </div>

            <!-- Mockup: ScrapingSchool -->
            <div class="mb-4">
              <div class="mockup-placeholder w-full h-44 flex flex-col p-3 gap-2" aria-hidden="true">
