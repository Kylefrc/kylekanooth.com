---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section id="blog" aria-labelledby="blog-heading" class="py-20 md:py-28 border-t border-[var(--c-border)]">
  <div class="max-w-6xl mx-auto px-5 md:px-8">

    <div class="reveal mb-12">
      <span class="text-[#22d3ee] text-xs uppercase tracking-[0.2em] font-medium" aria-hidden="true">Blog</span>
      <h2 id="blog-heading" class="mt-3 font-display text-3xl sm:text-4xl font-bold text-[var(--c-text-pri)]">From the field</h2>
      <p class="mt-3 text-[var(--c-text-sec)] max-w-xl">Notes on building software while running a real business. Practical, not theoretical.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" role="list" aria-label="Recent blog posts">
      {posts.map((post, i) => (
        <article
          role="listitem"
          class="reveal card-hover bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl p-6 flex flex-col"
          data-delay={String(i + 1)}
        >
          <div class="flex items-center gap-3 mb-4">
            <time
              datetime={post.data.date.toISOString().split('T')[0]}
              class="text-xs text-[var(--c-text-mut)]"
            >
              {post.data.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
            </time>
            <span class="text-[var(--c-border)]" aria-hidden="true">·</span>
            <span class="text-xs text-[var(--c-text-mut)]">{post.data.readTime}</span>
          </div>

          <h3 class="font-display text-lg font-semibold text-[var(--c-text-pri)] leading-snug mb-3">
            {post.data.title}
          </h3>

          <p class="text-[var(--c-text-sec)] text-sm leading-relaxed flex-1 mb-5">
            {post.data.description}
          </p>

          <a
            href={`/blog/${post.slug}`}
            class="inline-flex items-center gap-1.5 text-[#22d3ee] text-sm font-medium hover:text-[#67e8f9] transition-colors link-animated"
            aria-label={`Read "${post.data.title}"`}
          >
            Read more
            <svg aria-hidden="true" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

    <div class="reveal mt-10 text-center">
      <a href="/blog" class="btn-ghost text-sm">
        View all posts
        <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>
