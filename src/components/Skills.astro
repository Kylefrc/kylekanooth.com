---
---

<section id="skills" aria-labelledby="skills-heading" class="py-16 md:py-20 border-t border-[var(--c-border)]">
  <div class="max-w-6xl mx-auto px-5 md:px-8">

    <div class="reveal mb-10">
      <span class="text-[#2D5016] text-xs uppercase tracking-[0.2em] font-medium" aria-hidden="true">Skills</span>
      <h2 id="skills-heading" class="mt-2 font-display text-2xl font-bold text-[var(--c-text-pri)]">Tools &amp; technologies</h2>
    </div>

    <div class="reveal grid sm:grid-cols-2 lg:grid-cols-4 gap-8">

      <!-- Languages & frameworks -->
      <div>
        <p class="text-[#2D5016] text-xs uppercase tracking-[0.2em] font-medium mb-3">Languages &amp; frameworks</p>
        <ul class="flex flex-wrap gap-2" aria-label="Languages and frameworks">
          <li class="tag">Python</li>
          <li class="tag">TypeScript</li>
          <li class="tag">React</li>
          <li class="tag">FastAPI</li>
          <li class="tag">Astro</li>
          <li class="tag">Node.js</li>
          <li class="tag">Tailwind CSS</li>
        </ul>
      </div>

      <!-- AI & automation -->
      <div>
        <p class="text-[#2D5016] text-xs uppercase tracking-[0.2em] font-medium mb-3">AI &amp; automation</p>
        <ul class="flex flex-wrap gap-2" aria-label="AI and automation tools">
          <li class="tag">Claude / Claude Code</li>
          <li class="tag">MCP</li>
          <li class="tag">Firecrawl</li>
          <li class="tag">Playwright</li>
          <li class="tag">Parallel agents</li>
          <li class="tag">Scheduled tasks</li>
        </ul>
      </div>

      <!-- Data & infra -->
      <div>
        <p class="text-[#2D5016] text-xs uppercase tracking-[0.2em] font-medium mb-3">Data &amp; infra</p>
        <ul class="flex flex-wrap gap-2" aria-label="Data and infrastructure tools">
          <li class="tag">PostgreSQL</li>
          <li class="tag">SQLAlchemy</li>
          <li class="tag">SQLite</li>
          <li class="tag">REST APIs</li>
          <li class="tag">Netlify</li>
          <li class="tag">Git</li>
        </ul>
      </div>

      <!-- Energy + Contracting Expertise -->
      <div>
        <p class="text-[#2D5016] text-xs uppercase tracking-[0.2em] font-medium mb-3">Energy + Contracting Expertise</p>
        <p class="text-[var(--c-text-mut)] text-xs leading-relaxed mb-3">ServiceTitan API, BPI building science, ETO/PCEF compliance, Manual J sizing, blower-door testing — 100+ residential retrofits.</p>
        <ul class="flex flex-wrap gap-2" aria-label="Energy and contracting domain skills">
          <li class="tag">ServiceTitan API</li>
          <li class="tag">SNUGG Pro</li>
          <li class="tag">BPI standards</li>
          <li class="tag">Energy modeling</li>
          <li class="tag">Manual J</li>
          <li class="tag">Blower door testing</li>
          <li class="tag">ETO/PCEF rebates</li>
        </ul>
      </div>

    </div>

  </div>
</section>
