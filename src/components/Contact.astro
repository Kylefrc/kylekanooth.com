---
---

<section id="contact" aria-labelledby="contact-heading" class="py-20 md:py-28 border-t border-[var(--c-border)]">
  <div class="max-w-6xl mx-auto px-5 md:px-8 grid md:grid-cols-2 gap-12 md:gap-20 items-start">

    <!-- Left column: intro + contact info -->
    <div>
      <span class="reveal text-[#2D5016] text-xs uppercase tracking-[0.2em] font-medium" aria-hidden="true">Contact</span>
      <h2 id="contact-heading" class="reveal mt-3 font-display text-3xl sm:text-4xl font-bold text-[var(--c-text-pri)]">Let's work together</h2>
      <p class="reveal mt-4 text-[var(--c-text-sec)] leading-relaxed">
        I'm open to consulting on AI automation, technical recruiting conversations, and partnerships on the projects above. Send a message or reach out directly.
      </p>

      <address class="reveal mt-6 flex flex-col gap-3 not-italic">
        <a
          href="mailto:kyle.kanooth@gmail.com"
          class="inline-flex items-center gap-2.5 text-[#2D5016] hover:text-[#6B8F5E] transition-colors font-medium link-animated"
        >
          <!-- Mail icon -->
          <svg aria-hidden="true" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          kyle.kanooth@gmail.com
        </a>
        <a
          href="https://linkedin.com/in/kyle-kanooth"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 text-[#2D5016] hover:text-[#6B8F5E] transition-colors font-medium link-animated"
          aria-label="LinkedIn profile (opens in new tab)"
        >
          <!-- LinkedIn icon -->
          <svg aria-hidden="true" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          linkedin.com/in/kyle-kanooth
        </a>
      </address>

      <dl class="reveal mt-8 space-y-4">
        <div class="flex gap-3 items-start">
          <span class="mt-0.5 w-2 h-2 rounded-full bg-[#2D5016] flex-shrink-0" aria-hidden="true"></span>
          <div>
            <dt class="inline text-[var(--c-text-mut)] text-sm">Response time: </dt>
            <dd class="inline text-[var(--c-text-pri)] text-sm">1 business day</dd>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="mt-0.5 w-2 h-2 rounded-full bg-[#2D5016] flex-shrink-0" aria-hidden="true"></span>
          <div>
            <dt class="inline text-[var(--c-text-mut)] text-sm">Location: </dt>
            <dd class="inline text-[var(--c-text-pri)] text-sm">Portland, OR (remote-friendly)</dd>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="mt-0.5 w-2 h-2 rounded-full bg-[#2D5016] flex-shrink-0" aria-hidden="true"></span>
          <div>
            <dt class="inline text-[var(--c-text-mut)] text-sm">Open to: </dt>
            <dd class="inline text-[var(--c-text-pri)] text-sm">Energy tech consulting, technical recruiting, and engineering partnerships on SnuggSpec or Scraping School.</dd>
          </div>
        </div>
      </dl>
    </div>

    <!-- Right column: contact form -->
    <div class="reveal bg-[var(--c-surface)] border border-[var(--c-border)] rounded-2xl p-6 md:p-8">
      <form
        id="contact-form"
        name="contact"
        method="POST"
        data-netlify="true"
        aria-label="Contact form"
        novalidate
      >
        <input type="hidden" name="form-name" value="contact" />

        <div class="space-y-4">
          <div>
            <label for="f-name" class="block text-sm font-medium text-[var(--c-text-sec)] mb-1.5">Name<span class="text-red-500 ml-0.5" aria-hidden="true">*</span></label>
            <input
              id="f-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              aria-required="true"
              placeholder="Your name"
              class="w-full bg-[var(--c-bg)] border border-[var(--c-border)] rounded-xl px-4 py-3 text-[var(--c-text-pri)] placeholder:text-[var(--c-text-mut)] focus:outline-none focus:border-[rgba(45,80,22,0.5)] focus:ring-1 focus:ring-[rgba(45,80,22,0.3)] transition"
            />
          </div>

          <div>
            <label for="f-email" class="block text-sm font-medium text-[var(--c-text-sec)] mb-1.5">Email<span class="text-red-500 ml-0.5" aria-hidden="true">*</span></label>
            <input
              id="f-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              aria-required="true"
              placeholder="you@example.com"
              class="w-full bg-[var(--c-bg)] border border-[var(--c-border)] rounded-xl px-4 py-3 text-[var(--c-text-pri)] placeholder:text-[var(--c-text-mut)] focus:outline-none focus:border-[rgba(45,80,22,0.5)] focus:ring-1 focus:ring-[rgba(45,80,22,0.3)] transition"
            />
          </div>

          <div>
            <label for="f-message" class="block text-sm font-medium text-[var(--c-text-sec)] mb-1.5">What's on your mind?<span class="text-red-500 ml-0.5" aria-hidden="true">*</span></label>
            <textarea
              id="f-message"
              name="message"
              rows="5"
              required
              aria-required="true"
              placeholder="Tell me what you're building, what you need, or just say hi."
              class="w-full bg-[var(--c-bg)] border border-[var(--c-border)] rounded-xl px-4 py-3 text-[var(--c-text-pri)] placeholder:text-[var(--c-text-mut)] focus:outline-none focus:border-[rgba(45,80,22,0.5)] focus:ring-1 focus:ring-[rgba(45,80,22,0.3)] transition resize-none"
            ></textarea>
          </div>
        </div>

        <button type="submit" class="mt-5 w-full btn-primary justify-center">
          Send message
          <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
        <p class="mt-2 text-xs text-[var(--c-text-mut)]"><span class="text-red-500" aria-hidden="true">*</span> Required field</p>
        <p class="mt-2 text-center text-xs text-[var(--c-text-mut)]">No spam. Just a real conversation.</p>
        <p
          id="contact-error"
          class="hidden mt-3 text-center text-sm text-red-500"
          role="alert"
          aria-live="assertive"
        >
          Submission failed &mdash; email me directly at <a href="mailto:kyle.kanooth@gmail.com" class="underline">kyle.kanooth@gmail.com</a>.
        </p>
      </form>

      <!-- Success state (hidden by default, shown after submit) -->
      <div
        id="contact-success"
        class="hidden text-center py-10"
        role="status"
        aria-live="polite"
        tabindex="-1"
      >
        <div class="w-14 h-14 mx-auto rounded-full bg-[rgba(45,80,22,0.1)] border border-[rgba(45,80,22,0.2)] flex items-center justify-center mb-4" aria-hidden="true">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="w-7 h-7 text-[#2D5016]">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-semibold text-[var(--c-text-pri)]">Message sent.</h3>
        <p class="mt-2 text-[var(--c-text-sec)]">I'll get back to you within one business day.</p>
      </div>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');
  const errorMsg = document.getElementById('contact-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    // Hide any previous error
    errorMsg?.classList.add('hidden');

    let submitted = false;
    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as any).toString(),
      });
      submitted = res.ok;
    } catch {
      submitted = false;
    }

    if (submitted) {
      form.classList.add('hidden');
      if (success) {
        success.classList.remove('hidden');
        success.focus();
      }
    } else {
      errorMsg?.classList.remove('hidden');
    }
  });
</script>
